   "outputs": [],
   "source": [
    "def bootstrap_sample(x):\n",
    "    N = len(x)\n",
    "    u = np.random.uniform(0, 1, N)\n",
    "    v = (np.floor(N * u) + 1).astype(int)\n",
    "    return x[v - 1]"
   ]
  }
